{
  "manifest_version": 3,
  "name": "Recall — Search History by Content",
  "short_name": "Recall",
  "version": "1.0.0",
  "description": "Search your browsing history by the words on the page, not just titles & URLs. 100% local — your pages never leave your device.",
  "minimum_chrome_version": "105",
  "permissions": ["storage"],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://extensionpay.com/*"],
      "js": ["src/lib/ExtPay.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/lib/config.js", "src/lib/index.js", "src/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "Recall: search your browsing by content",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "src/options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
