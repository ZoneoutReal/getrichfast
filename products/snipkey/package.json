{
  "name": "snipkey",
  "private": true,
  "version": "1.0.1",
  "description": "SnipKey — text expander Chrome extension. Dev tooling: tests, icon/screenshot generation, packaging.",
  "type": "module",
  "scripts": {
    "test": "npm run test:engine && npm run test:ui",
    "test:engine": "node tests/run-tests.mjs",
    "test:ui": "node tests/run-ui-tests.mjs",
    "icons": "node scripts/make-icons.mjs",
    "shots": "node scripts/make-screenshots.mjs",
    "tiles": "node scripts/make-promo-tiles.mjs",
    "build": "bash scripts/build.sh"
  },
  "devDependencies": {
    "playwright": "1.56.1"
  }
}
